{
  "seed": 42,
  "image_size": 224,
  "normalize_mean": [0.485, 0.456, 0.406],
  "normalize_std": [0.229, 0.224, 0.225],
  "masking": "rgb",
  "crop_to_bbox": true,
  "square_crop": true,
  "bbox_input": true,
  "normalize_bbox": true,
  "model": "dinov2",
  "dinov2_model": "dinov2_vits14",
  "feature_dim": 384,
  "freeze_encoder": true,
  "head": [512, 128, 1],
  "loss": "l1",
  "optimizer": "adam",
  "learning_rate": 0.001,
  "batch_size": 32,
  "epochs": 100,
  "num_workers": 4,
  "train_groups": [2, 3, 4, 5, 7, 8, 9, 12, 13, 15, 16, 18, 19, 23, 24],
  "val_groups": [1, 6, 11, 17, 25],
  "test_groups": [10, 14, 20, 21, 22]
}
