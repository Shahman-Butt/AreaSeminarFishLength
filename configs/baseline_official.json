{
  "seed": 42,
  "image_size": 224,
  "masking": "rgb",
  "crop_to_bbox": true,
  "square_crop": true,
  "bbox_input": true,
  "normalize_bbox": true,
  "model": "mobilenet_v2",
  "pretrained": true,
  "freeze_encoder": false,
  "head": [1000, 500, 1],
  "loss": "l1",
  "optimizer": "adam",
  "learning_rate": 0.001,
  "batch_size": 32,
  "epochs": 200,
  "num_workers": 4,
  "train_groups": [2, 3, 4, 5, 7, 8, 9, 12, 13, 15, 16, 18, 19, 23, 24],
  "val_groups": [1, 6, 11, 17, 25],
  "test_groups": [10, 14, 20, 21, 22]
}
